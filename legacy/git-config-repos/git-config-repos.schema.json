{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/LuisPalacios/gitbox/main/legacy/git-config-repos/git-config-repos.schema.json",
    "title": "git-config-repos configuration",
    "description": "Configuration file for git-config-repos.sh — manages Git multi-account environments across multiple providers (GitHub, GitLab, Gitea).",
    "type": "object",
    "required": ["global", "accounts"],
    "additionalProperties": false,
    "properties": {
        "$schema": {
            "type": "string",
            "description": "JSON Schema URI for editor validation and autocompletion."
        },
        "global": {
            "type": "object",
            "description": "Global settings: root directory, SSH and GCM credential configuration.",
            "required": ["folder"],
            "additionalProperties": false,
            "properties": {
                "folder": {
                    "type": "string",
                    "description": "Root directory for all git repositories. Supports ~ prefix or absolute path."
                },
                "credential_ssh": {
                    "type": "object",
                    "description": "SSH credential management settings.",
                    "additionalProperties": false,
                    "properties": {
                        "enabled": {
                            "type": "string",
                            "enum": ["true", "false"],
                            "description": "Enable SSH credential management."
                        },
                        "ssh_folder": {
                            "type": "string",
                            "description": "Path to SSH config directory. Supports ~ prefix."
                        }
                    }
                },
                "credential_gcm": {
                    "type": "object",
                    "description": "Git Credential Manager (HTTPS) settings.",
                    "additionalProperties": false,
                    "properties": {
                        "enabled": {
                            "type": "string",
                            "enum": ["true", "false"],
                            "description": "Enable Git Credential Manager (HTTPS) authentication."
                        },
                        "helper": {
                            "type": "string",
                            "description": "Credential helper type (typically 'manager')."
                        },
                        "credentialStore": {
                            "type": "string",
                            "enum": ["wincredman", "keychain", "secretservice"],
                            "description": "OS-specific credential storage backend: wincredman (Windows), keychain (macOS), secretservice (Linux)."
                        }
                    }
                }
            }
        },
        "accounts": {
            "type": "object",
            "description": "Map of account identifiers to account configurations. Keys are free-form names chosen by the user.",
            "additionalProperties": {
                "type": "object",
                "description": "A Git provider account with its repositories.",
                "required": ["url", "username", "folder", "name", "email", "repos"],
                "additionalProperties": false,
                "properties": {
                    "url": {
                        "type": "string",
                        "format": "uri",
                        "description": "Provider base URL, optionally with user/org path (e.g. https://github.com/User). Omit user path for cross-org clones."
                    },
                    "username": {
                        "type": "string",
                        "description": "Account username on the Git provider."
                    },
                    "folder": {
                        "type": "string",
                        "description": "Subdirectory name under global.folder for this account's repos."
                    },
                    "name": {
                        "type": "string",
                        "description": "Default git user.name for repos in this account."
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "description": "Default git user.email for repos in this account."
                    },
                    "gcm_provider": {
                        "type": "string",
                        "enum": ["github", "gitlab", "bitbucket", "generic"],
                        "description": "GCM provider hint. Optional — omit to skip global gitconfig entry."
                    },
                    "gcm_useHttpPath": {
                        "type": "string",
                        "enum": ["true", "false"],
                        "description": "If 'true', GCM scopes credentials by HTTP path. Optional."
                    },
                    "ssh_host": {
                        "type": "string",
                        "description": "SSH config Host alias (e.g. gh-MyUser). Required if any repo uses credential_type 'ssh'."
                    },
                    "ssh_hostname": {
                        "type": "string",
                        "description": "Real SSH server hostname (e.g. github.com). Required alongside ssh_host."
                    },
                    "ssh_type": {
                        "type": "string",
                        "enum": ["ed25519", "rsa"],
                        "description": "SSH key type to generate."
                    },
                    "repos": {
                        "type": "object",
                        "description": "Map of repository names to repo configurations. Names may contain slashes for cross-org repos (e.g. 'org/repo').",
                        "additionalProperties": {
                            "type": "object",
                            "description": "Configuration for a single repository.",
                            "required": ["credential_type"],
                            "additionalProperties": false,
                            "properties": {
                                "credential_type": {
                                    "type": "string",
                                    "enum": ["gcm", "ssh"],
                                    "description": "Authentication method for this repository."
                                },
                                "name": {
                                    "type": "string",
                                    "description": "Override git user.name for this specific repo."
                                },
                                "email": {
                                    "type": "string",
                                    "format": "email",
                                    "description": "Override git user.email for this specific repo."
                                },
                                "folder": {
                                    "type": "string",
                                    "description": "Custom clone path. Absolute (starts with / or ~) or relative to account folder."
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
