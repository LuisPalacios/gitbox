# gitbox developer environment
#
# Copy this file to the repo root as .env and fill in your remote SSH hosts.
# This file is gitignored — it contains private hostnames.
#
# How it works:
#   - The scripts auto-detect your local OS (win/mac-arm/mac-intel/linux)
#   - Your local machine runs commands directly — no SSH needed
#   - Remote machines are accessed via SSH (key-based auth required)
#   - Leave a variable empty or omit it to skip that platform
#
# macOS is split into two targets so Apple Silicon (arm64) and Intel (amd64)
# machines can coexist in one .env. If you only own one Mac, leave the other
# variable empty.
#
# Scenario 1: Developing on Windows, remotes are both Macs and Linux
#   SSH_WIN_HOST=""
#   SSH_MAC_ARM_HOST="user@mac-arm-host"
#   SSH_MAC_INTEL_HOST="user@mac-intel-host"
#   SSH_LINUX_HOST="user@linux-host"
#
# Scenario 2: Developing on Apple Silicon, remotes are Windows, Intel Mac, Linux
#   SSH_WIN_HOST="user@win-host"
#   SSH_MAC_ARM_HOST=""
#   SSH_MAC_INTEL_HOST="user@mac-intel-host"
#   SSH_LINUX_HOST="user@linux-host"
#
# Scenario 3: Developing on Linux, remote is a single Mac
#   SSH_WIN_HOST=""
#   SSH_MAC_ARM_HOST="user@mac-host"
#   SSH_MAC_INTEL_HOST=""
#   SSH_LINUX_HOST=""
#
# Scenario 4: Local-only (no cross-platform testing)
#   Leave all variables empty. Scripts will only run locally.
#
# Verify SSH works before using the scripts:
#   ssh -o ConnectTimeout=5 user@host 'echo ok'

# Windows remote (user@host). Leave empty if this is your local machine.
SSH_WIN_HOST=""

# macOS Apple Silicon (arm64) remote. Leave empty if this is your local machine
# or if you do not have an Apple Silicon Mac.
SSH_MAC_ARM_HOST=""

# macOS Intel (amd64) remote. Leave empty if this is your local machine or if
# you do not have an Intel Mac.
SSH_MAC_INTEL_HOST=""

# Linux remote (user@host). Leave empty if this is your local machine or unavailable.
SSH_LINUX_HOST=""
