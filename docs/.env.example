# gitbox developer environment
#
# Copy this file to the repo root as .env and fill in your remote SSH hosts.
# This file is gitignored — it contains private hostnames.
#
# How it works:
#   - The scripts auto-detect your local OS (win-intel/win-arm/mac-arm/mac-intel/linux)
#   - Your local machine runs commands directly — no SSH needed
#   - Remote machines are accessed via SSH (key-based auth required)
#   - Leave a variable empty or omit it to skip that platform
#
# Windows and macOS each split into two targets so amd64 and arm64 machines
# can coexist in one .env. If you only own one of each, leave the other
# variable empty.
#
# Scenario 1: Developing on Windows amd64, remotes are both Macs and Linux
#   SSH_WIN_INTEL_HOST=""
#   SSH_WIN_ARM_HOST=""
#   SSH_MAC_ARM_HOST="user@mac-arm-host"
#   SSH_MAC_INTEL_HOST="user@mac-intel-host"
#   SSH_LINUX_HOST="user@linux-host"
#
# Scenario 2: Developing on Apple Silicon, remotes include a Windows amd64 box,
#             a Windows-on-ARM VM (e.g. Parallels), Intel Mac, and Linux
#   SSH_WIN_INTEL_HOST="user@win-amd64-host"
#   SSH_WIN_ARM_HOST="user@win-arm-vm"
#   SSH_MAC_ARM_HOST=""
#   SSH_MAC_INTEL_HOST="user@mac-intel-host"
#   SSH_LINUX_HOST="user@linux-host"
#
# Scenario 3: Developing on Linux, remote is a single Mac
#   SSH_WIN_INTEL_HOST=""
#   SSH_WIN_ARM_HOST=""
#   SSH_MAC_ARM_HOST="user@mac-host"
#   SSH_MAC_INTEL_HOST=""
#   SSH_LINUX_HOST=""
#
# Scenario 4: Local-only (no cross-platform testing)
#   Leave all variables empty. Scripts will only run locally.
#
# Verify SSH works before using the scripts:
#   ssh -o ConnectTimeout=5 user@host 'echo ok'

# Windows amd64 (Intel/AMD x64) remote (user@host). Leave empty if this is
# your local machine or you don't have an amd64 Windows box.
SSH_WIN_INTEL_HOST=""

# Windows arm64 (Windows-on-ARM) remote (user@host). Typical source is a
# Parallels Desktop / VMware Fusion VM running Windows 11 for ARM on Apple
# Silicon. Leave empty if you don't have one.
SSH_WIN_ARM_HOST=""

# Legacy alias — older .env files used a single SSH_WIN_HOST for the one
# Windows box they had. The scripts still honor it as a fallback for
# SSH_WIN_INTEL_HOST, so you don't have to rename immediately, but new
# setups should prefer SSH_WIN_INTEL_HOST.
#SSH_WIN_HOST=""

# macOS Apple Silicon (arm64) remote. Leave empty if this is your local machine
# or if you do not have an Apple Silicon Mac.
SSH_MAC_ARM_HOST=""

# macOS Intel (amd64) remote. Leave empty if this is your local machine or if
# you do not have an Intel Mac.
SSH_MAC_INTEL_HOST=""

# Linux remote (user@host). Leave empty if this is your local machine or unavailable.
SSH_LINUX_HOST=""
