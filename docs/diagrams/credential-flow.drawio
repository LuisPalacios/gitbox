        <mxCell id="gcm_git" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" value="GCM handles&#xa;git auth directly" vertex="1">
